# Server
PORT=5000
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=your-secret-key-here-change-in-production

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OpenAI (Optional - for enhanced LLM features, falls back to simple rule-based if not provided)
OPENAI_API_KEY=your-openai-api-key

# Google Translate
GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key

# Supabase (Required for DB + Storage persistence)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=audio
MOCK_USER_ID=mock-user

# Database (Supabase PostgreSQL) - Optional for MVP
DATABASE_URL=postgresql://user:password@host:port/database
